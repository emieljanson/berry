POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Keep this fixed if you want one stable device in PostHog.
# Example: ANALYTICS_DISTINCT_ID=berry-livingroom
ANALYTICS_DISTINCT_ID=

# Privacy defaults are strict; keep these off unless you need detail.
ANALYTICS_INCLUDE_CONTENT=0
# For multiple Pi devices, set this to 1 to keep each Pi unique.
ANALYTICS_USE_MACHINE_ID=1
